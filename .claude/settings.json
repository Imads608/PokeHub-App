{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npx nx affected:*)",
      "Bash(npx nx run:*)",
      "Bash(npx nx run-many:*)",
      "Bash(npx nx test:*)",
      "Bash(npx nx lint:*)",
      "Bash(npx nx typecheck:*)",
      "Bash(npx nx typecheck-spec:*)",
      "Bash(npx nx build:*)",
      "Bash(npx nx serve:*)",
      "Bash(npx nx e2e:*)",
      "Bash(npx nx show:*)",
      "Bash(npx nx graph:*)",
      "Bash(npx nx g:*)",
      "Bash(npx nx generate:*)",
      "Bash(nx e2e:*)",
      "Bash(npx playwright test:*)",
      "Bash(npx prettier:*)",
      "Bash(npx eslint:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(gh run *)",
      "Bash(gh pr view:*)",
      "Bash(gh pr checks:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)"
    ],
    "ask": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/format-lint.mjs\""
          }
        ]
      }
    ]
  }
}
