{
  "name": "pokehub-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/pokehub-app",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/next:build",
      "outputs": [
        "{options.outputPath}"
      ],
      "dependsOn": [
        "^build"
      ],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/pokehub-app"
      },
      "configurations": {
        "development": {
          "outputPath": "apps/pokehub-app"
        },
        "production": {
          "webpack": true
        }
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next dev apps/pokehub-app -p 4200 --webpack | pino-pretty"
      },
      "configurations": {
        "development": {
          "buildTarget": "pokehub-app:build:development",
          "dev": true
        },
        "production": {
          "buildTarget": "pokehub-app:build:production",
          "dev": false
        }
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next start dist/apps/pokehub-app -p 4200"
      }
    },
    "export": {
      "executor": "@nx/next:export",
      "options": {
        "buildTarget": "pokehub-app:build:production"
      }
    },
    "verify": {
      "executor": "@nx/next:build",
      "outputs": [
        "{options.outputPath}"
      ],
      "dependsOn": [
        "^build",
        "^lint",
        "^test"
      ],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/pokehub-app"
      },
      "configurations": {
        "development": {
          "outputPath": "apps/pokehub-app"
        },
        "production": {
          "webpack": true
        }
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "apps/pokehub-app/jest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "analyze": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ANALYZE=true nx build pokehub-app --configuration=production",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
